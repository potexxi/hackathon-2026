<Window x:Class="Hackathon.MainWindowMap"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Hackathon"
        xmlns:mapsui="clr-namespace:Mapsui.UI.Wpf;assembly=Mapsui.UI.Wpf"
        mc:Ignorable="d"
        Title="MainWindowMap" Height="450" Width="800">
    <Canvas>
        <mapsui:MapControl x:Name="mapControl" Width="800" Height="400"  />
        <Button Width="100" Height="35" Content="Next Point" x:Name="NextButton" Canvas.Top="400" Click="NextButton_Click"></Button>
    </Canvas>
</Window>
