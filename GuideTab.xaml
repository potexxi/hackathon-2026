<Window x:Class="Hackathon.GuideTab"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Hackathon"
        mc:Ignorable="d"
        Title="GuideTab" Height="450" Width="800">
    <Grid>
        <Rectangle HorizontalAlignment="Center" Height="113" Stroke="Black" VerticalAlignment="Top" Width="800" Fill="LightGray"/>
        <Button FontSize="40" FontWeight="Bold" Content="Back" HorizontalAlignment="Center" Margin="0,285,0,0" VerticalAlignment="Top" Height="97" Width="470" Click="Button_Click"/>
        <Label x:Name ="Titel" FontSize="35" Content="TITEL" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,32,0,0" VerticalAlignment="Top" Height="60" Width="532"/>
        <Label x:Name ="SubTitel" FontSize="11" Content="SUB TEXT" HorizontalAlignment="Center" Margin="0,175,0,0" VerticalAlignment="Top" Height="105" Width="658"/>
        <Label x:Name ="Text" Content="Label" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,129,0,0" VerticalAlignment="Top" Height="71" Width="658"/>
    </Grid>
</Window>
