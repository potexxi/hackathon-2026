<Window x:Class="Hackathon.GuideTab"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Hackathon"
        mc:Ignorable="d"
        Title="GuideTab" Height="450" Width="300">
    <Grid>
        <Button Content="Back" HorizontalAlignment="Center" Margin="0,339,0,0" VerticalAlignment="Top" Height="65" Width="252" Click="Button_Click"/>
        <Label x:Name ="Titel" Content="TITEL" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,32,0,0" VerticalAlignment="Top" Height="60" Width="252"/>
        <Label x:Name ="SubTitel" Content="SUB TEXT" HorizontalAlignment="Center" Margin="0,138,0,0" VerticalAlignment="Top" Height="196" Width="228"/>
        <Label x:Name ="Text" Content="Label" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,74,0,0" VerticalAlignment="Top" Height="64" Width="252"/>
    </Grid>
</Window>
