<UserControl x:Class="Hackathon.GuideEntry"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Hackathon"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="800">
    <Grid>
        <Rectangle  Height="100" Fill="White" RadiusX="20" RadiusY="20"/>
        <Label x:Name="LabelTitel" FontSize="25" FontWeight="Bold" Margin="26,0,-26,0">
            <TextBlock Text="How to find water" TextDecorations="None"/>
        </Label>

        <Label x:Name="LabelSubtext" Content="You go Into maps and get GOOD" Margin="66,40,103,0" RenderTransformOrigin="0.5,0.5"/>
        <Rectangle Height="100" Fill="Transparent" MouseEnter="Rectangle_MouseEnter"  MouseLeave="Rectangle_MouseLeave" PreviewMouseDown="Rectangle_PreviewMouseDown"/>
    </Grid>
</UserControl>
